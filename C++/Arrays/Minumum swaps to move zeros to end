class Solution {
public:  
    int minimumSwaps(vector<int>& nums) {
        int j=nums.size()-1;
        int count=0;
        for(int i=0;i<j;i++){
            
                if(nums[i]==0){
                    while(i<j && nums[j]==0){
                    j--;}
                    if(i>=j)
                     return count;
                  swap(nums[i],nums[j]);
                  count++;
                  j--;
                }
        }
        return count;
    }
};
